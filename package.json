{
  "name": "regraft",
  "version": "0.1.1",
  "description": "Copy code from any git repo, change it for your project, and keep pulling upstream updates later.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/treadiehq/regraft.git"
  },
  "homepage": "https://github.com/treadiehq/regraft#readme",
  "license": "FSL-1.1-MIT",
  "bin": {
    "regraft": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "build:binary": "bash scripts/build-release.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
